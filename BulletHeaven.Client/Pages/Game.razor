@page "/"
@inject IJSRuntime JS
@inject HttpClient Http
@using BulletHeaven.Client.Game
@using BulletHeaven.Client.Game.Collision
@using BulletHeaven.Client.Game.Pools
@using BulletHeaven.Client.Game.Upgrades
@using System.Net.Http.Json
@using System.Net.Http.Headers

<PageTitle>Bullet Heaven</PageTitle>

<div class="game-container">

    @if (_state == GameState.MainMenu)
    {
        <div class="menu-overlay">
            <div class="menu-logo">BULLET HEAVEN</div>
            @if (_loggedInUser != null)
            {
                <p class="menu-greeting">Welcome back, <span>@_loggedInUser</span>!</p>
            }
            else
            {
                <p class="menu-sub">Survive as long as you can</p>
            }
            <div class="menu-buttons">
                <button class="btn-normal"      @onclick="StartGame">Start Game</button>
                <button class="btn-leaderboard" @onclick="ShowLeaderboard">Leaderboard</button>
                <button class="btn-codex"       @onclick='() => { _codexTab = "enemies"; _state = GameState.Codex; StateHasChanged(); }'>Archive</button>
            </div>
            @if (_loggedInUser != null)
            {
                <div class="signed-in-badge">
                    <span class="signed-in-dot"></span>
                    Signed in as <b>@_loggedInUser</b>
                </div>
            }
            else
            {
                <p class="menu-sub" style="font-size:0.85rem;margin-top:4px;color:#64748b">Sign in at the portal to save scores</p>
            }
            @if (_highScore > 0)
            {
                <p class="menu-best">Best score: @_highScore.ToString("N0")</p>
            }
        </div>
    }

    @if (_state == GameState.Leaderboard)
    {
        <div class="codex-overlay">
            <div class="codex-header">
                <span class="codex-title">LEADERBOARD</span>
                <button class="btn-back" @onclick='() => { _state = GameState.MainMenu; StateHasChanged(); }'>← Back</button>
            </div>
            <div style="padding: 24px; overflow-y: auto; flex: 1;">
                @if (_leaderboardLoading)
                {
                    <p style="color:#64748b; font-family: monospace;">Loading...</p>
                }
                else if (_leaderboard == null)
                {
                    <p style="color:#ef4444; font-family: monospace;">Could not load leaderboard.</p>
                }
                else if (_leaderboard.Count == 0)
                {
                    <p style="color:#64748b; font-family: monospace;">No scores yet — be the first!</p>
                }
                else
                {
                    <table class="leaderboard-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Player</th>
                                <th>Score</th>
                                <th>Kills</th>
                                <th>Level</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < _leaderboard.Count; i++)
                            {
                                var entry     = _leaderboard[i];
                                var rank      = i + 1;
                                var rankClass = rank == 1 ? "rank-gold" : rank == 2 ? "rank-silver" : rank == 3 ? "rank-bronze" : "";
                                <tr class="@(entry.Username == _loggedInUser ? "row-self" : "")">
                                    <td class="@rankClass">@rank</td>
                                    <td>@entry.Username</td>
                                    <td>@entry.Value.ToString("N0")</td>
                                    <td>@entry.Kills</td>
                                    <td>@entry.Level</td>
                                    <td>@entry.PlayedAt.ToLocalTime().ToString("MMM d")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }

    @if (_state == GameState.Codex)
    {
        <div class="codex-overlay">
            <div class="codex-header">
                <span class="codex-title">ARCHIVE</span>
                <div class="codex-tabs">
                    <button class="codex-tab @(_codexTab == "enemies"  ? "active" : "")" @onclick='() => _codexTab = "enemies"'>Enemies</button>
                    <button class="codex-tab @(_codexTab == "weapons"  ? "active" : "")" @onclick='() => _codexTab = "weapons"'>Weapons</button>
                    <button class="codex-tab @(_codexTab == "upgrades" ? "active" : "")" @onclick='() => _codexTab = "upgrades"'>Upgrades</button>
                </div>
                <button class="btn-back" @onclick='() => { _state = GameState.MainMenu; StateHasChanged(); }'>← Back</button>
            </div>

            <div class="codex-body">
                @if (_codexTab == "enemies")
                {
                    <div class="enemy-card">
                        <div class="enemy-card-top">
                            <canvas data-entity="standard" width="90" height="90" class="enemy-canvas"></canvas>
                            <div><div class="enemy-name">Standard</div><div class="enemy-tier">Common</div></div>
                        </div>
                        <div class="enemy-desc">The basic horde. Slow and steady — dangerous when they surround you.</div>
                        <div class="enemy-stats">
                            <span>HP</span><b>1</b>
                            <span>Speed</span><b>Normal</b>
                            <span>XP</span><b>1</b>
                            <span>Score</span><b>10</b>
                            <span>Spawn</span><b>60% chance</b>
                        </div>
                    </div>
                    <div class="enemy-card">
                        <div class="enemy-card-top">
                            <canvas data-entity="runner" width="90" height="90" class="enemy-canvas"></canvas>
                            <div><div class="enemy-name">Runner</div><div class="enemy-tier">Common</div></div>
                        </div>
                        <div class="enemy-desc">Lightning-fast and fragile. Closes the gap in seconds — never let them group up.</div>
                        <div class="enemy-stats">
                            <span>HP</span><b>1</b>
                            <span>Speed</span><b>1.5× normal</b>
                            <span>XP</span><b>1</b>
                            <span>Score</span><b>15</b>
                            <span>Spawn</span><b>25% chance</b>
                        </div>
                    </div>
                    <div class="enemy-card">
                        <div class="enemy-card-top">
                            <canvas data-entity="tank" width="90" height="90" class="enemy-canvas"></canvas>
                            <div><div class="enemy-name">Tank</div><div class="enemy-tier">Uncommon</div></div>
                        </div>
                        <div class="enemy-desc">Armored brute. Slow but takes multiple hits to bring down — prioritise them early.</div>
                        <div class="enemy-stats">
                            <span>HP</span><b>3</b>
                            <span>Speed</span><b>0.5× normal</b>
                            <span>XP</span><b>3</b>
                            <span>Score</span><b>25</b>
                            <span>Spawn</span><b>12% chance</b>
                        </div>
                    </div>
                    <div class="enemy-card">
                        <div class="enemy-card-top">
                            <canvas data-entity="elite" width="90" height="90" class="enemy-canvas"></canvas>
                            <div><div class="enemy-name">Elite</div><div class="enemy-tier">Rare</div></div>
                        </div>
                        <div class="enemy-desc">Fast and tough. High threat level — worth targeting first for the XP boost.</div>
                        <div class="enemy-stats">
                            <span>HP</span><b>5</b>
                            <span>Speed</span><b>1.2× normal</b>
                            <span>XP</span><b>8</b>
                            <span>Score</span><b>80</b>
                            <span>Spawn</span><b>3% chance</b>
                        </div>
                    </div>
                    <div class="enemy-card">
                        <div class="enemy-card-top">
                            <canvas data-entity="boss" width="90" height="90" class="enemy-canvas"></canvas>
                            <div><div class="enemy-name">Boss</div><div class="enemy-tier">Boss</div></div>
                        </div>
                        <div class="enemy-desc">Spawns every 2 minutes. Massive HP — killing it grants 2 bonus upgrade selections.</div>
                        <div class="enemy-stats">
                            <span>HP</span><b>40</b>
                            <span>Speed</span><b>0.6× normal</b>
                            <span>XP</span><b>30</b>
                            <span>Score</span><b>500</b>
                            <span>Spawn</span><b>Every 120s</b>
                        </div>
                    </div>
                }
                @if (_codexTab == "weapons")
                {
                    <div class="weapon-card">
                        <div class="weapon-icon">🔫</div>
                        <div class="weapon-name">Primary Shot</div>
                        <div class="weapon-tag">Auto-fire · Always active</div>
                        <div class="weapon-desc">Fires automatically at the nearest enemy. Upgrades: split shot, triple shot, bullet speed, piercing, homing, ricochet, and explosive kills.</div>
                    </div>
                    <div class="weapon-card">
                        <div class="weapon-icon">🌀</div>
                        <div class="weapon-name">Orb Shield</div>
                        <div class="weapon-tag">Contact damage · Unlocked via upgrade</div>
                        <div class="weapon-desc">Orbiting spheres that deal damage on contact. Add more orbs or expand the orbit radius through upgrades. Each orb has a 0.4s hit cooldown per enemy.</div>
                    </div>
                    <div class="weapon-card">
                        <div class="weapon-icon">💥</div>
                        <div class="weapon-name">Pulse Nova</div>
                        <div class="weapon-tag">Area explosion · Unlocked via upgrade</div>
                        <div class="weapon-desc">Triggers a massive explosion around you every 3 seconds, instantly clearing all enemies in range. Upgrade to expand the blast radius further.</div>
                    </div>
                    <div class="weapon-card">
                        <div class="weapon-icon">⚡</div>
                        <div class="weapon-name">Damage Aura</div>
                        <div class="weapon-tag">Passive field · Unlocked via upgrade</div>
                        <div class="weapon-desc">A constant damage field surrounds you, dealing a tick of damage every 0.5s to all nearby enemies. Upgrade to extend the aura's reach.</div>
                    </div>
                }
                @if (_codexTab == "upgrades")
                {
                    <div class="codex-rarity-group">Common</div>
                    @foreach (var u in UpgradeCatalogue.All.Where(u => u.Rarity == UpgradeRarity.Common))
                    {
                        <div class="upgrade-card rarity-common">
                            <span class="upgrade-rarity">@u.Rarity</span>
                            <span class="upgrade-name">@u.Name</span>
                            <span class="upgrade-desc">@u.Description</span>
                        </div>
                    }
                    <div class="codex-rarity-group">Rare</div>
                    @foreach (var u in UpgradeCatalogue.All.Where(u => u.Rarity == UpgradeRarity.Rare))
                    {
                        <div class="upgrade-card rarity-rare">
                            <span class="upgrade-rarity">@u.Rarity</span>
                            <span class="upgrade-name">@u.Name</span>
                            <span class="upgrade-desc">@u.Description</span>
                        </div>
                    }
                    <div class="codex-rarity-group">Epic</div>
                    @foreach (var u in UpgradeCatalogue.All.Where(u => u.Rarity == UpgradeRarity.Epic))
                    {
                        <div class="upgrade-card rarity-epic">
                            <span class="upgrade-rarity">@u.Rarity</span>
                            <span class="upgrade-name">@u.Name</span>
                            <span class="upgrade-desc">@u.Description</span>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @if (_state == GameState.PausedLevelUp)
    {
        <div class="menu-overlay">
            <h1>LEVEL UP!</h1>
            <p>Choose an upgrade</p>
            <div class="upgrade-cards">
                @foreach (var u in _upgradeChoices)
                {
                    var upgrade = u;
                    <button class="upgrade-card rarity-@upgrade.Rarity.ToString().ToLower()"
                            @onclick="() => ApplyUpgrade(upgrade)">
                        <span class="upgrade-rarity">@upgrade.Rarity</span>
                        <span class="upgrade-name">@upgrade.Name</span>
                        <span class="upgrade-desc">@upgrade.Description</span>
                    </button>
                }
            </div>
        </div>
    }

    @if (_state == GameState.GameOver)
    {
        <div class="menu-overlay">
            <h1 style="color:#ef4444">GAME OVER</h1>
            <p style="color:#94a3b8">@TimeSpan.FromSeconds(_difficulty.ElapsedTime).ToString(@"mm\:ss") survived &nbsp;|&nbsp; Level @(_level + 1) &nbsp;|&nbsp; @_totalKills kills</p>
            <p style="color:#ffffff">Score: @_score.ToString("N0")</p>
            <p style="color:#f59e0b">Best: @_highScore.ToString("N0")</p>
            @if (_loggedInUser != null && _personalBest is { Count: > 0 })
            {
                <div class="personal-best">
                    <div class="personal-best-title">YOUR BEST RUNS</div>
                    <table class="personal-best-table">
                        <tbody>
                            @{ var currentRunMarked = false; }
                            @foreach (var run in _personalBest)
                            {
                                var isCurrentRun = !currentRunMarked && run.Value == _score;
                                if (isCurrentRun) { currentRunMarked = true; }
                                <tr class="@(isCurrentRun ? "row-self" : "")">
                                    <td>@run.Value.ToString("N0")</td>
                                    <td>@run.Kills kills</td>
                                    <td>Lv @run.Level</td>
                                    <td>@run.PlayedAt.ToLocalTime().ToString("MMM d")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            <div class="menu-buttons">
                <button class="btn-normal"      @onclick="StartGame">Play Again</button>
                <button class="btn-leaderboard" @onclick="ShowLeaderboard">Leaderboard</button>
                <button class="btn-codex"       @onclick='() => { _state = GameState.MainMenu; StateHasChanged(); }'>Main Menu</button>
            </div>
        </div>
    }

    <BECanvas Width="@_canvasW" Height="@_canvasH" @ref="_canvasRef" />

</div>

@code {
    private BECanvasComponent _canvasRef = default!;
    private Canvas2DContext _ctx = default!;
    private DotNetObjectReference<Game> _dotNetRef = default!;

    private enum GameState { MainMenu, Playing, PausedLevelUp, GameOver, Codex, Leaderboard }
    private GameState _state    = GameState.MainMenu;
    private string    _codexTab = "enemies";

    // Auth state — populated from portal JWT in localStorage on init
    private string? _jwtToken;
    private string? _loggedInUser;

    // Leaderboard state
    private record LeaderboardEntry(string Username, int Value, int Kills, int Level, DateTime PlayedAt);
    private List<LeaderboardEntry>? _leaderboard;
    private bool _leaderboardLoading;

    // Personal best state (game-over panel, signed-in players only)
    private record PersonalBestEntry(int Value, int Kills, int Level, DateTime PlayedAt);
    private List<PersonalBestEntry>? _personalBest;

    private readonly GameLoop _gameLoop = new();
    private InputHandler _inputHandler = default!;
    private readonly Player _player = new();
    // POOL-001/002: fixed pre-allocated pools — spawn = activate a slot, kill = flip IsAlive; zero new during gameplay
    private readonly EnemyPool _enemies = new();
    private readonly BulletPool _projectiles = new();
    private readonly EntityPool<XpGem> _xpGems = new(600);
    private readonly EnemySpawner _spawner = new();
    // QUAD-002: broad-phase index, rebuilt every frame; candidate lists are reused to keep the tick allocation-free
    private readonly Quadtree<Enemy> _enemyTree = new(0, 0, 800, 600);
    private readonly List<Enemy> _queryCandidates = new(64);
    private readonly List<Enemy> _explosionCandidates = new(64);
    private readonly Weapon _weapon = new();
    private readonly OrbWeapon   _orbWeapon   = new();
    private readonly PulseWeapon _pulseWeapon = new();
    private readonly AuraWeapon  _auraWeapon  = new();
    // Concrete array: foreach over an interface-typed list boxes the enumerator every frame
    private readonly ISecondaryWeapon[] _secondaryWeapons;
    private readonly DifficultyManager _difficulty = new();
    private WeaponStats _weaponStats = new();
    private readonly ParticleSystem _particles = new();

    private int    _canvasW = 800;
    private int    _canvasH = 600;
    private bool   _contextCreated;

    private double _playerAngle;
    private int    _kills;
    private int    _totalKills;
    private int    _level;
    private int    _xp;
    private int    _xpNeeded = 20;
    private int    _score;
    private int    _highScore;
    private int    _combo;
    private double _comboTimer;
    private double _shakeTimer;
    private double _shakeX;
    private double _shakeY;
    private double _bossTimer    = 120.0;
    private double _bossWarningTimer;
    private int    _pendingExtraRewards;
    private List<UpgradeDefinition> _upgradeChoices = new();

    // HUD string caches — interpolated strings allocate, so each label is
    // rebuilt only when its source value changes, never per frame
    private string _hudFpsText = "FPS: 0";
    private double _hudFpsCooldown;
    private string _hudTimeText = "00:00";
    private int    _hudTimeSecond = -1;
    private string _hudLevelKillsText = "";
    private int    _hudKillsCached = -1, _hudLevelCached = -1;
    private string _hudXpText = "";
    private int    _hudXpCached = -1, _hudXpNeededCached = -1;
    private string _hudScoreText = "Score: 0";
    private int    _hudScoreCached = -1;
    private string _hudComboText = "";
    private int    _hudComboCached = -1;
    private string _hudHpText = "";
    private int    _hudHpCached = -1, _hudMaxHpCached = -1;
    private string _hudBossText = "";
    private int    _hudBossHpCached = -1;
    private string _hudUserText = "";

    public Game() => _secondaryWeapons = [_orbWeapon, _pulseWeapon, _auraWeapon];

    private int    KillsNeeded     => 10 + _level * 5;
    private double ComboMultiplier => _combo switch { >= 20 => 3.0, >= 10 => 2.0, >= 5 => 1.5, _ => 1.0 };

    // Allocation-free nearest-alive lookup for per-frame homing (no LINQ/closures in the tick path).
    private Enemy? FindNearestAliveEnemy(double x, double y)
    {
        Enemy? nearest = null;
        var minDistSq = double.MaxValue;
        var slots = _enemies.Slots;
        for (var i = 0; i < slots.Length; i++)
        {
            var e = slots[i];
            if (!e.IsAlive) continue;
            var dx = e.X - x;
            var dy = e.Y - y;
            var distSq = dx * dx + dy * dy;
            if (distSq < minDistSq) { minDistSq = distSq; nearest = e; }
        }
        return nearest;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var size = await JS.InvokeAsync<int[]>("gameInterop.getViewportSize");
            _canvasW = size[0];
            _canvasH = size[1];
            GameBounds.Width  = _canvasW;
            GameBounds.Height = _canvasH;
            StateHasChanged();
            return;
        }

        if (!_contextCreated)
        {
            _contextCreated = true;
            _ctx = await _canvasRef.CreateCanvas2DAsync();
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("gameInterop.startLoop", _dotNetRef);
            _inputHandler = new InputHandler(JS);
            await _inputHandler.InitAsync();
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "bh_highscore");
            if (int.TryParse(saved, out var hs)) _highScore = hs;
            var savedToken = await JS.InvokeAsync<string?>("localStorage.getItem", "jwt");
            if (!string.IsNullOrEmpty(savedToken))
            {
                _jwtToken     = savedToken;
                _loggedInUser = ParseUsernameFromJwt(savedToken);
                _hudUserText  = _loggedInUser == null ? "" : $"◉ {_loggedInUser}";
            }
            _state = GameState.MainMenu;
            StateHasChanged();
            return;
        }

        if (_state == GameState.Codex && _codexTab == "enemies")
            await JS.InvokeVoidAsync("gameInterop.drawEntityPreviews");
    }

    [JSInvokable]
    public async Task Tick(double timestamp)
    {
        _gameLoop.ProcessTick(timestamp);

        // always poll input so edge flags are consumed every frame
        var (vx, vy, space, r) = await _inputHandler.GetInputAsync();

        if (r && _state == GameState.Playing) { StartGame(); return; }

        if (_state == GameState.MainMenu      ||
            _state == GameState.Codex         ||
            _state == GameState.GameOver      ||
            _state == GameState.Leaderboard   ||
            _state == GameState.PausedLevelUp) { await Render(); return; }

        if (_state == GameState.Playing)
        {
            var dt = _gameLoop.DeltaTime;

            if (space) _gameLoop.IsPaused = !_gameLoop.IsPaused;

            if (!_gameLoop.IsPaused)
            {
                _difficulty.Update(dt);
                if (vx != 0 || vy != 0) _playerAngle = Math.Atan2(vy, vx);
                _player.Update(dt, vx, vy);
                _spawner.Update(dt, _enemies, _difficulty.CurrentSpawnInterval, _difficulty.CurrentEnemySpeed, _difficulty.CurrentEnemiesPerWave);

                // boss timer
                _bossTimer -= dt;
                if (_bossWarningTimer > 0) _bossWarningTimer -= dt;
                if (_bossTimer <= 3.0 && _bossWarningTimer <= 0) _bossWarningTimer = 3.0;
                if (_bossTimer <= 0) { _bossTimer = 120.0; _spawner.SpawnBoss(_enemies, _difficulty.CurrentEnemySpeed); }

                // combo decay
                if (_comboTimer > 0) { _comboTimer -= dt; if (_comboTimer <= 0) _combo = 0; }

                // screen shake decay
                if (_shakeTimer > 0)
                {
                    _shakeTimer -= dt;
                    _shakeX = (Random.Shared.NextDouble() - 0.5) * 10;
                    _shakeY = (Random.Shared.NextDouble() - 0.5) * 10;
                }
                else { _shakeX = 0; _shakeY = 0; }

                var enemySlots = _enemies.Slots;
                for (var ei = 0; ei < enemySlots.Length; ei++)
                {
                    var e = enemySlots[ei];
                    if (!e.IsAlive) continue;
                    e.Update(dt, _player.X, _player.Y);
                    e.HitFlash = Math.Max(0, e.HitFlash - dt);
                }

                _weapon.Update(dt, _player, _enemies, _projectiles, _weaponStats);

                var bulletSlots = _projectiles.Slots;
                for (var pi = 0; pi < bulletSlots.Length; pi++)
                {
                    var p = bulletSlots[pi];
                    if (!p.IsAlive) continue;
                    p.Update(dt);

                    // homing steering
                    if (_weaponStats.HomingStrength > 0)
                    {
                        var nearest = FindNearestAliveEnemy(p.X, p.Y);
                        if (nearest != null)
                            p.ApplyHoming(_weaponStats.HomingStrength, nearest.X, nearest.Y);
                    }

                    // ricochet off walls
                    if (p.RicochetLeft > 0)
                    {
                        if (p.X < 0 || p.X > _canvasW) { p.Vx = -p.Vx; p.RicochetLeft--; p.X = Math.Clamp(p.X, 0, _canvasW); }
                        if (p.Y < 0 || p.Y > _canvasH) { p.Vy = -p.Vy; p.RicochetLeft--; p.Y = Math.Clamp(p.Y, 0, _canvasH); }
                    }

                    // culling: off-screen bullets release their pool slot instead of leaking
                    if (p.RicochetLeft == 0 && p.IsOffScreen()) p.IsAlive = false;
                }

                _particles.Update(dt);

                // secondary weapons
                var killsThisFrame = 0;
                foreach (var w in _secondaryWeapons)
                    killsThisFrame += w.Update(dt, _player, _enemies, _weaponStats);

                // QUAD-002: rebuild the spatial index from live enemies, then collide against candidates only
                _enemyTree.Clear(0, 0, GameBounds.Width, GameBounds.Height);
                for (var ti = 0; ti < enemySlots.Length; ti++)
                    if (enemySlots[ti].IsAlive) _enemyTree.Insert(enemySlots[ti]);

                // collision: projectile × enemy
                for (var pi = 0; pi < bulletSlots.Length; pi++)
                {
                    var p = bulletSlots[pi];
                    if (!p.IsAlive) continue;
                    _enemyTree.Query(p.X, p.Y, p.Radius, _queryCandidates);
                    for (var ci = 0; ci < _queryCandidates.Count; ci++)
                    {
                        var e = _queryCandidates[ci];
                        if (!e.IsAlive) continue;
                        if (GameMath.CirclesOverlap(p, e))
                        {
                            e.HitFlash = 0.12;
                            if (e.TakeDamage())
                            {
                                killsThisFrame += e.KillValue;
                                _score         += (int)(e.ScoreValue * ComboMultiplier);
                                _combo++;
                                _comboTimer = 3.0;
                                for (var gi = 0; gi < e.XpValue; gi++)
                                    if (_xpGems.TryRent(out var gem)) gem.Activate(e.X, e.Y);
                                if (_player.HpRegenPerKill > 0) _player.Heal(_player.HpRegenPerKill);
                                if (e.Type == EnemyType.Boss) _pendingExtraRewards += 2;
                                _particles.Emit(e.X, e.Y, EnemyColor(e.Type));

                                // explosive chain
                                if (_weaponStats.ExplosionRadius > 0)
                                {
                                    _particles.Emit(e.X, e.Y, "#f97316", 15);
                                    _enemyTree.Query(e.X, e.Y, _weaponStats.ExplosionRadius, _explosionCandidates);
                                    for (var oi = 0; oi < _explosionCandidates.Count; oi++)
                                    {
                                        var o = _explosionCandidates[oi];
                                        if (!o.IsAlive || o == e ||
                                            GameMath.Distance(e, o) >= _weaponStats.ExplosionRadius + o.Radius) continue;
                                        if (o.TakeDamage())
                                        {
                                            killsThisFrame += o.KillValue;
                                            _score         += (int)(o.ScoreValue * ComboMultiplier);
                                            _combo++;
                                            _comboTimer = 3.0;
                                            for (var gi = 0; gi < o.XpValue; gi++)
                                                if (_xpGems.TryRent(out var gem)) gem.Activate(o.X, o.Y);
                                            _particles.Emit(o.X, o.Y, EnemyColor(o.Type));
                                        }
                                    }
                                }
                            }
                            if (p.PiercingLeft > 0) p.PiercingLeft--;
                            else { p.IsAlive = false; break; }
                        }
                    }
                }

                _kills      += killsThisFrame;
                _totalKills += killsThisFrame;

                // XP gems — collected gems just release their pool slot
                var gemSlots = _xpGems.Slots;
                for (var gi = 0; gi < gemSlots.Length; gi++)
                {
                    var g = gemSlots[gi];
                    if (!g.IsAlive) continue;
                    g.Update(dt, _player.X, _player.Y, _player.MagnetRange);
                    if (GameMath.CirclesOverlap(g, _player)) { _xp += g.Value; g.IsAlive = false; }
                }

                // collision: enemy × player (broad-phase candidates around the player)
                _enemyTree.Query(_player.X, _player.Y, _player.Radius, _queryCandidates);
                for (var ci = 0; ci < _queryCandidates.Count; ci++)
                {
                    var e = _queryCandidates[ci];
                    if (e.IsAlive && GameMath.CirclesOverlap(e, _player))
                    {
                        if (!_player.IsInvincible && !_player.IsDead) _shakeTimer = 0.25;
                        _player.TakeDamage();
                    }
                }

                // level-up priority: boss rewards → kill threshold → xp threshold
                if (_pendingExtraRewards > 0) { _pendingExtraRewards--; TriggerBossReward(); }
                else if (_kills >= KillsNeeded) TriggerLevelUp();
                else if (_xp >= _xpNeeded) TriggerXpLevelUp();

                if (_player.IsDead)
                {
                    if (_score > _highScore)
                    {
                        _highScore = _score;
                        await JS.InvokeVoidAsync("localStorage.setItem", "bh_highscore", _highScore.ToString());
                    }
                    _state = GameState.GameOver;
                    StateHasChanged();
                    if (_jwtToken != null)
                    {
                        await SubmitScoreAsync();
                        await FetchPersonalBestAsync();
                        StateHasChanged();
                    }
                }
            }
        }

        await Render();
    }

    // Rebuilds HUD labels whose source values changed since the last frame.
    // FPS is throttled to twice a second so its label doesn't reallocate on jitter.
    private void RefreshHudCaches()
    {
        _hudFpsCooldown -= _gameLoop.DeltaTime;
        if (_hudFpsCooldown <= 0)
        {
            _hudFpsCooldown = 0.5;
            _hudFpsText = $"FPS: {_gameLoop.Fps:F0}";
        }

        var second = (int)_difficulty.ElapsedTime;
        if (second != _hudTimeSecond)
        {
            _hudTimeSecond = second;
            _hudTimeText = TimeSpan.FromSeconds(second).ToString(@"mm\:ss");
        }

        if (_kills != _hudKillsCached || _level != _hudLevelCached)
        {
            _hudKillsCached = _kills;
            _hudLevelCached = _level;
            _hudLevelKillsText = $"Lv {_level + 1}  Kills: {_kills}/{KillsNeeded}";
        }

        if (_xp != _hudXpCached || _xpNeeded != _hudXpNeededCached)
        {
            _hudXpCached = _xp;
            _hudXpNeededCached = _xpNeeded;
            _hudXpText = $"XP: {_xp}/{_xpNeeded}";
        }

        if (_score != _hudScoreCached)
        {
            _hudScoreCached = _score;
            _hudScoreText = $"Score: {_score:N0}";
        }

        if (_combo != _hudComboCached)
        {
            _hudComboCached = _combo;
            _hudComboText = $"COMBO x{_combo}  {ComboMultiplier:0.#}x";
        }

        if (_player.CurrentHealth != _hudHpCached || _player.MaxHealth != _hudMaxHpCached)
        {
            _hudHpCached = _player.CurrentHealth;
            _hudMaxHpCached = _player.MaxHealth;
            _hudHpText = $"HP {_player.CurrentHealth}/{_player.MaxHealth}";
        }
    }

    private async Task Render()
    {
        await _ctx.BeginBatchAsync();

        await _ctx.SaveAsync();
        if (_shakeX != 0 || _shakeY != 0) await _ctx.TranslateAsync(_shakeX, _shakeY);

        await _ctx.ClearRectAsync(-10, -10, _canvasW + 20, _canvasH + 20);

        if (_state == GameState.Playing || _state == GameState.GameOver)
        {
            // aura ring
            if (_weaponStats.AuraRadius > 0)
            {
                var auraAlpha = 0.10 + 0.05 * Math.Sin(_difficulty.ElapsedTime * 4);
                await _ctx.SetGlobalAlphaAsync((float)auraAlpha);
                await _ctx.SetStrokeStyleAsync("#818cf8");
                await _ctx.SetLineWidthAsync(2);
                await _ctx.BeginPathAsync();
                await _ctx.ArcAsync(_player.X, _player.Y, _weaponStats.AuraRadius, 0, Math.PI * 2);
                await _ctx.StrokeAsync();
                await _ctx.SetGlobalAlphaAsync(1.0f);
            }

            // player — flash semi-transparent when invincible
            await _ctx.SetGlobalAlphaAsync(_player.IsInvincible ? 0.4f : 1.0f);
            await DrawPlayer(_player.X, _player.Y, _playerAngle);
            await _ctx.SetGlobalAlphaAsync(1.0f);

            // XP gems
            await _ctx.SetFillStyleAsync("#4ade80");
            var gemSlots = _xpGems.Slots;
            for (var gi = 0; gi < gemSlots.Length; gi++)
            {
                var g = gemSlots[gi];
                if (!g.IsAlive) continue;
                await _ctx.BeginPathAsync();
                await _ctx.ArcAsync(g.X, g.Y, g.Radius, 0, Math.PI * 2);
                await _ctx.FillAsync();
            }

            // enemies (shaped + hit flash overlay + HP bars)
            var enemySlots = _enemies.Slots;
            for (var ei = 0; ei < enemySlots.Length; ei++)
            {
                var e = enemySlots[ei];
                if (!e.IsAlive) continue;
                await DrawEnemy(e, _difficulty.ElapsedTime);

                if (e.HitFlash > 0)
                {
                    await _ctx.SetGlobalAlphaAsync(0.55f);
                    await _ctx.SetFillStyleAsync("#ffffff");
                    await _ctx.BeginPathAsync();
                    await _ctx.ArcAsync(e.X, e.Y, e.Radius, 0, Math.PI * 2);
                    await _ctx.FillAsync();
                    await _ctx.SetGlobalAlphaAsync(1.0f);
                }

                if (e.MaxHealth > 1)
                {
                    var bw = e.Radius * 2;
                    var bx = e.X - e.Radius;
                    var by = e.Y - e.Radius - 7;
                    await _ctx.SetFillStyleAsync("#333");
                    await _ctx.FillRectAsync(bx, by, bw, 4);
                    await _ctx.SetFillStyleAsync("#22c55e");
                    await _ctx.FillRectAsync(bx, by, bw * e.CurrentHealth / e.MaxHealth, 4);
                }
            }

            // projectiles
            await _ctx.SetFillStyleAsync("#fbbf24");
            var bulletSlots = _projectiles.Slots;
            for (var pi = 0; pi < bulletSlots.Length; pi++)
            {
                var p = bulletSlots[pi];
                if (!p.IsAlive) continue;
                await _ctx.BeginPathAsync();
                await _ctx.ArcAsync(p.X, p.Y, p.Radius, 0, Math.PI * 2);
                await _ctx.FillAsync();
            }

            // orbiting orbs
            await _ctx.SetFillStyleAsync("#fef9c3");
            for (var oi = 0; oi < _orbWeapon.ActiveOrbCount; oi++)
            {
                var (ox, oy) = _orbWeapon.GetOrbPosition(oi);
                await _ctx.BeginPathAsync();
                await _ctx.ArcAsync(ox, oy, 8, 0, Math.PI * 2);
                await _ctx.FillAsync();
            }

            // pulse flash
            if (_pulseWeapon.JustPulsed && _weaponStats.PulseRadius > 0)
            {
                await _ctx.SetGlobalAlphaAsync(0.25f);
                await _ctx.SetFillStyleAsync("#818cf8");
                await _ctx.BeginPathAsync();
                await _ctx.ArcAsync(_player.X, _player.Y, _weaponStats.PulseRadius, 0, Math.PI * 2);
                await _ctx.FillAsync();
                await _ctx.SetGlobalAlphaAsync(1.0f);
            }

            // particles (pooled — expired slots have Life ≤ 0)
            var particleSlots = _particles.Particles;
            for (var qi = 0; qi < particleSlots.Length; qi++)
            {
                var pt = particleSlots[qi];
                if (pt.Life <= 0) continue;
                await _ctx.SetGlobalAlphaAsync((float)pt.Life);
                await _ctx.SetFillStyleAsync(pt.Color);
                await _ctx.BeginPathAsync();
                await _ctx.ArcAsync(pt.X, pt.Y, pt.Radius, 0, Math.PI * 2);
                await _ctx.FillAsync();
            }
            await _ctx.SetGlobalAlphaAsync(1.0f);

            // boss warning
            if (_bossWarningTimer > 0 && (int)(_difficulty.ElapsedTime * 4) % 2 == 0)
            {
                await _ctx.SetFillStyleAsync("#ef4444");
                await _ctx.SetFontAsync("bold 28px monospace");
                await _ctx.FillTextAsync("!! BOSS INCOMING !!", _canvasW / 2.0 - 190, _canvasH / 2.0);
            }

            // HUD — all labels come from the change-tracked string caches
            RefreshHudCaches();
            await _ctx.SetFontAsync("bold 16px monospace");
            await _ctx.SetFillStyleAsync(_gameLoop.IsPaused ? "#f59e0b" : "#ffffff");
            await _ctx.FillTextAsync(
                _gameLoop.IsPaused ? "PAUSED — press Space to resume" : _hudFpsText,
                10, 24);

            await _ctx.SetFillStyleAsync("#94a3b8");
            await _ctx.FillTextAsync(_hudTimeText, 10, 48);

            await _ctx.SetFillStyleAsync("#f59e0b");
            await _ctx.FillTextAsync(_hudLevelKillsText, 10, 72);

            await _ctx.SetFillStyleAsync("#4ade80");
            await _ctx.FillTextAsync(_hudXpText, 10, 96);

            await _ctx.SetFillStyleAsync("#ffffff");
            await _ctx.FillTextAsync(_hudScoreText, 10, 120);

            if (_combo >= 5)
            {
                await _ctx.SetFillStyleAsync("#f97316");
                await _ctx.FillTextAsync(_hudComboText, 10, 144);
            }

            // signed-in indicator (top-right)
            await _ctx.SetTextAlignAsync(TextAlign.Right);
            if (_loggedInUser != null)
            {
                await _ctx.SetFontAsync("bold 14px monospace");
                await _ctx.SetFillStyleAsync("#1fd6c4");
                await _ctx.FillTextAsync(_hudUserText, _canvasW - 12, 24);
                await _ctx.SetFontAsync("11px monospace");
                await _ctx.SetFillStyleAsync("#64748b");
                await _ctx.FillTextAsync("scores saved to leaderboard", _canvasW - 12, 42);
            }
            else
            {
                await _ctx.SetFontAsync("11px monospace");
                await _ctx.SetFillStyleAsync("#64748b");
                await _ctx.FillTextAsync("guest — sign in to save scores", _canvasW - 12, 24);
            }
            await _ctx.SetTextAlignAsync(TextAlign.Left);

            // health bar (bottom-left)
            await _ctx.SetFillStyleAsync("#333");
            await _ctx.FillRectAsync(10, _canvasH - 30.0, 150, 10);
            await _ctx.SetFillStyleAsync("#22c55e");
            await _ctx.FillRectAsync(10, _canvasH - 30.0, 150.0 * _player.CurrentHealth / _player.MaxHealth, 10);
            await _ctx.SetFontAsync("bold 9px monospace");
            await _ctx.SetFillStyleAsync("#fff");
            await _ctx.FillTextAsync(_hudHpText, 14, _canvasH - 21.0);

            // boss HP bar (bottom-center) — raw loop: Render runs every frame, no LINQ/closures here
            Enemy? boss = null;
            for (var bi = 0; bi < enemySlots.Length; bi++)
            {
                if (enemySlots[bi].IsAlive && enemySlots[bi].Type == EnemyType.Boss) { boss = enemySlots[bi]; break; }
            }
            if (boss != null)
            {
                if (boss.CurrentHealth != _hudBossHpCached)
                {
                    _hudBossHpCached = boss.CurrentHealth;
                    _hudBossText = $"BOSS  {boss.CurrentHealth}/{boss.MaxHealth}";
                }
                await _ctx.SetFillStyleAsync("#555");
                await _ctx.FillRectAsync((_canvasW - 300) / 2.0, _canvasH - 24.0, 300, 14);
                await _ctx.SetFillStyleAsync("#dc2626");
                await _ctx.FillRectAsync((_canvasW - 300) / 2.0, _canvasH - 24.0, 300.0 * boss.CurrentHealth / boss.MaxHealth, 14);
                await _ctx.SetFontAsync("bold 10px monospace");
                await _ctx.SetFillStyleAsync("#fff");
                await _ctx.FillTextAsync(_hudBossText, (_canvasW - 300) / 2.0 + 112, _canvasH - 13.0);
            }
        }

        await _ctx.RestoreAsync();

        await _ctx.EndBatchAsync();
    }

    private void StartGame()
    {
        _difficulty.Reset();
        _enemies.DeactivateAll();
        _projectiles.DeactivateAll();
        _xpGems.DeactivateAll();
        _particles.Clear();
        _player.Reset(_difficulty.PlayerMaxHealth, _difficulty.InvincibilityDuration);
        _spawner.Reset();
        _weapon.Reset();
        foreach (var w in _secondaryWeapons) w.Reset();
        _weaponStats = new WeaponStats();
        _kills = 0;
        _totalKills = 0;
        _level = 0;
        _xp = 0;
        _xpNeeded = 20;
        _score = 0;
        _combo = 0;
        _comboTimer = 0;
        _shakeTimer = 0;
        _bossTimer = 120.0;
        _bossWarningTimer = 0;
        _pendingExtraRewards = 0;
        _upgradeChoices.Clear();
        _gameLoop.IsPaused = false;
        _state = GameState.Playing;
        StateHasChanged();
    }

    private async Task ShowLeaderboard()
    {
        _state = GameState.Leaderboard;
        _leaderboardLoading = true;
        _leaderboard = null;
        StateHasChanged();
        try
        {
            _leaderboard = await Http.GetFromJsonAsync<List<LeaderboardEntry>>("api/leaderboard");
        }
        catch { _leaderboard = null; }
        _leaderboardLoading = false;
        StateHasChanged();
    }

    private async Task SubmitScoreAsync()
    {
        var request = new HttpRequestMessage(HttpMethod.Post, "api/scores")
        {
            Content = JsonContent.Create(new { Value = _score, Kills = _totalKills, Level = _level + 1 })
        };
        request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", _jwtToken);
        try { await Http.SendAsync(request); }
        catch { /* silent — score submission must never crash the game */ }
    }

    private async Task FetchPersonalBestAsync()
    {
        _personalBest = null;
        var request = new HttpRequestMessage(HttpMethod.Get, "api/scores/me");
        request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", _jwtToken);
        try
        {
            var resp = await Http.SendAsync(request);
            if (resp.IsSuccessStatusCode)
                _personalBest = await resp.Content.ReadFromJsonAsync<List<PersonalBestEntry>>();
        }
        catch { /* silent — the panel simply stays hidden */ }
    }

    private static string? ParseUsernameFromJwt(string? token)
    {
        if (token == null) return null;
        var parts = token.Split('.');
        if (parts.Length < 2) return null;
        var payload = parts[1];
        payload += new string('=', (4 - payload.Length % 4) % 4);
        var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(payload));
        using var doc = System.Text.Json.JsonDocument.Parse(json);
        return doc.RootElement.TryGetProperty("unique_name", out var v) ? v.GetString() : null;
    }

    private void EnterLevelUpState()
    {
        _upgradeChoices = UpgradeCatalogue.PickThree(_weaponStats, _player);
        _state = GameState.PausedLevelUp;
        StateHasChanged();
    }

    private void TriggerLevelUp()   { _kills = 0; _level++; EnterLevelUpState(); }
    private void TriggerXpLevelUp() { _xp = 0; _xpNeeded = (int)(_xpNeeded * 1.5); EnterLevelUpState(); }
    private void TriggerBossReward() => EnterLevelUpState();

    private void ApplyUpgrade(UpgradeDefinition u)
    {
        u.Apply(_weaponStats, _player);
        if (_pendingExtraRewards > 0) { _pendingExtraRewards--; TriggerBossReward(); }
        else { _state = GameState.Playing; StateHasChanged(); }
    }

    private static string EnemyColor(EnemyType type) => type switch
    {
        EnemyType.Runner => "#f97316",
        EnemyType.Tank   => "#7c3aed",
        EnemyType.Elite  => "#eab308",
        EnemyType.Boss   => "#dc2626",
        _                => "#ef4444",
    };

    public void Dispose()
    {
        _dotNetRef?.Dispose();
        JS.InvokeVoidAsync("gameInterop.stopLoop");
    }
}
